              {
                "key": "X-API-Key",
                "value": "{{api_secret_key}}",
                "description": "Optional \u2014 only required if API_SECRET_KEY is set on the server",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"database\": {\n    \"engine\": \"oracle\",\n    \"host\": \"localhost\",\n    \"port\": 1521,\n    \"service_name\": \"ORCL\",\n    \"dbname\": \"ORCL\",\n    \"user\": \"system\",\n    \"password\": \"yourpassword\",\n    \"schema\": \"BANKING\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/schema/test-connection",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "schema",
                "test-connection"
              ]
            }
          }
        },
