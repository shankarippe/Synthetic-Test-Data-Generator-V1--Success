{
  "info": {
    "name": "Synthetic Data Generation API",
    "description": "Synthetic Data Generation API \u2014 v2.1\n\n## Security\n- The Groq API key is configured **server-side only** via the `GROQ_API_KEY` env var.\n  It is never sent in any request body.\n- The `X-API-Key` header is optional. Enable it only if `API_SECRET_KEY` is set on the server.\n\n## Quick Start\n1. Start server: `python auto_pipeline.py --serve`\n2. Set `base_url` collection variable to `http://localhost:8000`\n3. Run **Health Check** \u2014 confirm `groq_key_configured: true`\n4. Run **Test Connection** \u2014 confirm DB is reachable\n5. Run **Run Pipeline (Async)** \u2014 job_id is saved automatically\n6. Run **Get Job Status** \u2014 poll until `status: completed`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "job_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "api_secret_key",
      "value": "",
      "description": "Set this only if the server has API_SECRET_KEY configured. Leave blank for local dev.",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "health"
              ]
            },
            "description": "Check API health and version info."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Schema",
      "item": [
        {
          "name": "Test Connection \u2014 PostgreSQL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_secret_key}}",
                "description": "Optional \u2014 only required if API_SECRET_KEY is set on the server",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"database\": {\n    \"engine\": \"postgres\",\n    \"host\": \"localhost\",\n    \"port\": 5432,\n    \"dbname\": \"DatagenDB\",\n    \"user\": \"postgres\",\n    \"password\": \"yourpassword\",\n    \"schema\": \"banking\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/schema/test-connection",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "schema",
                "test-connection"
              ]
            },
            "description": "Test PostgreSQL connection."
          }
        },
        {
          "name": "Test Connection \u2014 Oracle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
