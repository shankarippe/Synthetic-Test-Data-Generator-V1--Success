    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get Job Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_secret_key}}",
                "description": "Optional \u2014 only required if API_SECRET_KEY is set on the server",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "jobs",
                "{{job_id}}"
              ]
            },
            "description": "Poll this endpoint after starting an async pipeline run.\nStatus values: queued \u2192 running \u2192 completed | failed | cancelled"
          }
        },
        {
          "name": "List All Jobs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_secret_key}}",
