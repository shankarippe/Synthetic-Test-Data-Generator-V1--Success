              "raw": "{\n  \"database\": {\n    \"engine\": \"postgres\",\n    \"host\": \"localhost\",\n    \"port\": 5432,\n    \"dbname\": \"DatagenDB\",\n    \"user\": \"postgres\",\n    \"password\": \"yourpassword\",\n    \"schema\": \"banking\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/schema/read",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "schema",
                "read"
              ]
            },
            "description": "Read schema metadata (tables, columns, PKs, FKs) without generating data."
          }
        }
      ]
    },
    {
      "name": "Pipeline",
      "item": [
        {
          "name": "Run Pipeline \u2014 Synchronous (PostgreSQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_secret_key}}",
                "description": "Optional \u2014 only required if API_SECRET_KEY is set on the server",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"database\": {\n    \"engine\": \"postgres\",\n    \"host\": \"localhost\",\n    \"port\": 5432,\n    \"dbname\": \"DatagenDB\",\n    \"user\": \"postgres\",\n    \"password\": \"yourpassword\",\n    \"schema\": \"banking\"\n  },\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"batch_size\": 10000,\n  \"null_probability\": 0.05,\n  \"seed\": 42,\n  \"dry_run\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/pipeline/run",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "pipeline",
                "run"
              ]
            },
            "description": "Run full pipeline synchronously. Waits for completion.\nUse /run-async for large datasets."
          }
        },
        {
          "name": "Run Pipeline \u2014 Async (returns job_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "if (response.job_id) {",
                  "  pm.collectionVariables.set('job_id', response.job_id);",
                  "  console.log('Job ID saved:', response.job_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{api_secret_key}}",
                "description": "Optional \u2014 only required if API_SECRET_KEY is set on the server",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"database\": {\n    \"engine\": \"postgres\",\n    \"host\": \"localhost\",\n    \"port\": 5432,\n    \"dbname\": \"DatagenDB\",\n    \"user\": \"postgres\",\n    \"password\": \"yourpassword\",\n    \"schema\": \"banking\"\n  },\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"batch_size\": 10000,\n  \"null_probability\": 0.05,\n  \"seed\": 42,\n  \"dry_run\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/pipeline/run-async",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "pipeline",
                "run-async"
              ]
            },
            "description": "Start pipeline in background. Returns job_id immediately.\nAuto-saves job_id to collection variable for polling."
          }
        },
        {
          "name": "Run Pipeline \u2014 Oracle",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
